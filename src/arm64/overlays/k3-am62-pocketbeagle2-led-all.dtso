/dts-v1/;
/plugin/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/leds/common.h>

/*
 * Helper to show loaded overlays under: /proc/device-tree/chosen/overlays/
 */
&{/chosen} {
	overlays {
		k3-am62-pocketbeagle2-led-all.kernel = __TIMESTAMP__;
	};
};

&{/} {
	leds {
		compatible = "gpio-leds";
		pinctrl-names = "default";
		pinctrl-0 = <&P1_02_E18_gpio>,
					<&P1_04_D20_gpio>,
					<&P1_06_E19_gpio>,
					<&P1_08_gpio>,
					<&P1_10_A18_gpio>,
					<&P1_12_A19_gpio>,
					<&P1_13_gpio>,
					<&P1_19_gpio>,
					<&P1_20_gpio>,
					<&P1_21_gpio>,
					<&P1_23_gpio>,
					<&P1_25_gpio>,
					<&P1_27_gpio>,
					<&P1_29_gpio>,
					<&P1_31_gpio>,
					<&P1_33_A17_gpio>,
					<&P1_34_gpio>,
					<&P1_35_gpio>,
					<&P1_36_V20_gpio>;
		bootph-all;

		pin@102 {
			label = "P1_02";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 10 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@104 {
			label = "P1_04";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 12 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@106 {
			label = "P1_06";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 13 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@108 {
			label = "P1_08";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 14 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@110 {
			label = "P1_10";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 30 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@112 {
			label = "P1_12";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 8 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@113 {
			label = "P1_13";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio0 36 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@119 {
			label = "P1_19";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 1 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@120 {
			label = "P1_20";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio0 50 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@121 {
			label = "P1_21";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 6 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@123 {
			label = "P1_23";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 5 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@125 {
			label = "P1_25";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 4 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@127 {
			label = "P1_27";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 3 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@129 {
			label = "P1_29";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio0 62 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@131 {
			label = "P1_31";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio0 59 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@133 {
			label = "P1_33";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 29 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@134 {
			label = "P1_34";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio1 2 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@135 {
			label = "P1_35";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio0 88 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@136 {
			label = "P1_36";
			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio0 55 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};
	};
};
