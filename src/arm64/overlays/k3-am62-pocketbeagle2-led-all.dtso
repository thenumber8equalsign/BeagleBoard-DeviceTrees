};

&main_uart0 {
	pinctrl-0 = <>;
	status = "disabled";
};

&main_i2c2 {
	pinctrl-0 = <>;
	status = "disabled";
};

&ecap2 {
	pinctrl-0 = <>;
	status = "disabled";
};

&epwm2 {
	pinctrl-0 = <>;
	status = "disabled";
};
