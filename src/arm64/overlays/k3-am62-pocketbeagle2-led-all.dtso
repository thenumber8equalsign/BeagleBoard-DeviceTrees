			linux,default-trigger = "heartbeat";
			gpios = <&main_gpio0 59 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		pin@132 {
			label = "P1_32";
			linux,default-trigger = "heartbeat";
